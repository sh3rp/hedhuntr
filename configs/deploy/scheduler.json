{
  "_comment": "Container scheduler config. It publishes via configs/deploy/source-producer.json.",
  "sqlite": {
    "path": "/data/hedhuntr.db"
  },
  "source_producer_config": "/app/configs/deploy/source-producer.json",
  "poll_interval": "1m",
  "sources": [
    {
      "name": "example-static",
      "enabled": true,
      "schedule": "hourly",
      "interval": "1h",
      "timeout": "2m"
    }
  ]
}
