{
  "nats": {
    "url": "nats://nats:4222",
    "stream": "JOBS",
    "publish_timeout": "5s"
  },
  "sqlite": {
    "path": "/data/hedhuntr.db"
  },
  "consumer": {
    "durable": "automation-worker",
    "batch_size": 5,
    "fetch_wait": "2s",
    "max_in_flight": 64
  },
  "automation": {
    "mode": "packet-only",
    "allowed_adapters": ["greenhouse", "lever", "ashby", "workday", "generic"],
    "browser": {
      "enabled": false,
      "command": "xdg-open",
      "args": ["{url}"],
      "handoff_dir": "/data/automation-handoffs",
      "timeout": "10s"
    }
  }
}
